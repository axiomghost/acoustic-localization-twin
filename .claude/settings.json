{
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "powershell -NoProfile -File scripts\\session_start.ps1",
                        "shell": "powershell",
                        "timeout": 10,
                        "statusMessage": "Loading project state..."
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "powershell -NoProfile -File scripts\\governance_check.ps1",
                        "shell": "powershell",
                        "timeout": 10,
                        "statusMessage": "Checking governance..."
                    }
                ]
            }
        ]
    }
}
